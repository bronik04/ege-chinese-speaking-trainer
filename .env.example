DOMAIN=trainer.example.ru
TRAINER_PUBLIC_URL=https://trainer.example.ru
TRAINER_SECURE_COOKIE=1
TRAINER_LOG_LEVEL=INFO
TRAINER_DATA_DIR=/app/var
TRAINER_BIND_ADDRESS=127.0.0.1
TRAINER_PORT=8080
# SQLite используется по умолчанию. Эти значения нужны только с compose.scale.yml.
POSTGRES_DB=trainer
POSTGRES_USER=trainer
POSTGRES_PASSWORD=replace-with-a-long-random-password
# DATABASE_URL=postgresql://trainer:password@localhost:5432/trainer
TRAINER_MAX_AUDIO_SECONDS=210
TRAINER_MAX_AUDIO_BYTES=15000000
# Привилегированные действия доступны только подтверждённым email из списков.
TRAINER_TEACHER_EMAILS=
TRAINER_EDITOR_MODE=allowlist
TRAINER_EDITOR_EMAILS=
TRAINER_AUDIO_STORAGE=local
# Для Cloudflare R2: TRAINER_AUDIO_STORAGE=s3, endpoint https://<ACCOUNT_ID>.r2.cloudflarestorage.com
TRAINER_S3_BUCKET=
TRAINER_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
TRAINER_TRANSCRIPTION_ENABLED=0
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TRAINER_TRANSCRIPTION_LANGUAGE=zh
TRAINER_SMTP_HOST=smtp.example.ru
TRAINER_SMTP_PORT=465
TRAINER_SMTP_SSL=1
TRAINER_SMTP_USER=
TRAINER_SMTP_PASSWORD=
TRAINER_SMTP_FROM=noreply@example.ru
