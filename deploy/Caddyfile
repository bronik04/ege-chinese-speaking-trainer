{$DOMAIN} {
    encode zstd gzip
    request_body { max_size 16MB }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        Permissions-Policy "camera=(), geolocation=()"
    }
    reverse_proxy app:8080 {
        transport http {
            dial_timeout 5s
            response_header_timeout 30s
        }
    }
}
